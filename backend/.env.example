# --- Ambiente ---
PORT=3333
NODE_ENV=development

# --- CORS ---
# Em producao: URL do frontend no Vercel (ex: https://tracker.vercel.app)
FRONTEND_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# --- Firebase ---
FIREBASE_PROJECT_ID=trackermacro-5756a
# Desenvolvimento local: caminho para o arquivo JSON da service account
GOOGLE_APPLICATION_CREDENTIALS=
# Producao (Vercel): conteudo do JSON da service account em base64
# Gerar: base64 -i serviceAccount.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# --- Codigo de cadastro ---
# Obrigatorio em producao: string longa e aleatoria (ex: openssl rand -hex 32)
AUTH_CODE_SECRET=
AUTH_CODE_TTL_MINUTES=15

# --- Email (escolha uma das opcoes abaixo) ---
#
# OPCAO 1 — Resend (recomendado, mais simples)
# 1. Crie conta gratuita em https://resend.com
# 2. Gere uma API key em resend.com/api-keys
# 3. Cole a key abaixo
# 4. Configure MAIL_FROM com um remetente do seu dominio verificado
#    (ou use "Tracker <onboarding@resend.dev>" para testes — so envia para o email da sua conta Resend)
RESEND_API_KEY=
MAIL_FROM=

# OPCAO 2 — SMTP generico (Gmail, SendGrid, Mailgun, etc.)
# Gmail: habilite "Senhas de app" em myaccount.google.com/apppasswords
# --- Agente de IA (N8N) ---
# URL do webhook N8N que processa as mensagens do chat
N8N_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
